# ── Telegram Bot ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── WhatsApp (Twilio) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Email Alerts ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=recipient@example.com

# ── Google Maps ───────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── App Config ────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./crimewatch.db

# ── AI Model ──────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.45
MODEL_PATH=yolov8n.pt

# ── Face Recognition ──────────────────────────────────────────────
FACE_RECOGNITION_ENABLED=true
CRIMINAL_DB_PATH=criminal_db/

# ── Number Plate ──────────────────────────────────────────────────
ANPR_ENABLED=true
STOLEN_VEHICLES_DB=data/stolen_vehicles.json

# ── Audio Detection ───────────────────────────────────────────────
AUDIO_DETECTION_ENABLED=false
AUDIO_DEVICE_INDEX=0

# ── Alert Language ────────────────────────────────────────────────
ALERT_LANGUAGE=en
# Options: en, hi (Hindi), ta (Tamil), te (Telugu)

# ── Crime Prediction ──────────────────────────────────────────────
PREDICTION_MODEL_PATH=models/crime_predictor.pkl
